<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Override inline activity: hide Edit and Cancel for non-managers -->
    <t t-inherit="mail.Activity" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o-mail-Activity-edit')]" position="attributes">
            <attribute name="t-if">isManager</attribute>
        </xpath>
        <xpath expr="//button[hasclass('btn-danger')]" position="attributes">
            <attribute name="t-if">isManager</attribute>
        </xpath>
    </t>

</templates>
