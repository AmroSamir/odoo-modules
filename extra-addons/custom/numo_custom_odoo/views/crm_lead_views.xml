<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Inherit CRM Lead Form: Interest Details section before notebook -->
    <record id="view_crm_lead_form_inherit_numo" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.numo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Salesperson: readonly for agents, editable for leaders/managers, filtered to team members -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="readonly">x_team_readonly</attribute>
                <attribute name="domain">[('id', 'in', x_allowed_salesperson_ids)]</attribute>
                <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
            </xpath>

            <xpath expr="//notebook" position="before">
                <field name="x_allowed_product_ids" invisible="1"/>
                <field name="x_selectable_team_ids" invisible="1"/>
                <field name="x_team_readonly" invisible="1"/>
                <field name="x_allowed_salesperson_ids" invisible="1"/>
                <separator string="Interest Details"/>
                <group>
                    <group>
                        <field name="team_id"
                               readonly="x_team_readonly"
                               domain="[('id', 'in', x_selectable_team_ids)]"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="x_program_interest"
                               domain="[('id', 'in', x_allowed_product_ids)]"
                               options="{'no_create': True, 'no_open': True}"/>
                    </group>
                    <group>
                        <field name="x_submission_date"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Inherit CRM Lead List: show product column -->
    <record id="view_crm_lead_list_inherit_numo" model="ir.ui.view">
        <field name="name">crm.lead.list.inherit.numo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="before">
                <field name="x_program_interest" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- NOTE: team form additions (pricelist + analytic fields) live in
         views/studio_views.xml inside view_crm_team_form_project_fields,
         which replaces the right group entirely. Splitting them across
         two views caused the analytic fields to be wiped by the Studio
         replace. They are gated to base.group_system (admins) there. -->

</odoo>
