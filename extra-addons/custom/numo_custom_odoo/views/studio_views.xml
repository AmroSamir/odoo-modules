<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- crm.lead kanban: show program interest + team on card -->
    <record id="view_crm_lead_kanban_inherit_program" model="ir.ui.view">
        <field name="name">crm.lead.kanban.inherit.program</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_program_interest" class="text-muted small"/>
                <field name="team_id" class="text-muted small"/>
            </xpath>
        </field>
    </record>

    <!-- res.partner form: Saudi Student + Identity Number after tags -->
    <record id="view_res_partner_form_inherit_saudi_identity" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.saudi_identity</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="x_is_saudi" string="Saudi Student"/>
                <field name="x_identity_number" string="Identity Number" placeholder="1234567890"/>
            </xpath>
        </field>
    </record>

    <!-- res.partner form: Interests tab (opportunities list, read-only) -->
    <record id="view_res_partner_form_interests" model="ir.ui.view">
        <field name="name">res.partner.form.interests.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Interests" name="program_interests">
                    <field name="opportunity_ids" readonly="1">
                        <list string="Interests" create="0" delete="0" edit="0">
                            <field name="name" string="Opportunity"/>
                            <field name="x_submission_date" string="Submission Date"/>
                            <field name="x_program_interest" string="Program"/>
                            <field name="team_id" string="Project"/>
                            <field name="user_id" string="Sales Agent"/>
                            <field name="stage_id" string="Stage"/>
                            <field name="date_last_stage_update" string="Last Update"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- crm.team form: project info + admin-only Company/Pricelist/Analytic
         Replaces the standard right group entirely. Project info is visible
         to everyone; Company/Pricelist/Analytic fields are gated to admins
         (base.group_system) so non-admins see the same compact layout as
         on erp.amro.pro, while admins can still edit them via the UI. -->
    <record id="view_crm_team_form_project_fields" model="ir.ui.view">
        <field name="name">crm.team.form.numo.project.fields</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='right']" position="replace">
                <group name="right" string="معلومات المشروع">
                    <field name="x_project_state" widget="radio" options="{'horizontal': true}"/>
                    <field name="x_start_date"/>
                    <field name="x_end_date"/>
                    <field name="company_id" groups="base.group_system"/>
                    <field name="pricelist_id" groups="base.group_system"/>
                    <field name="analytic_project_id" groups="base.group_system"/>
                    <field name="analytic_team_type_id" groups="base.group_system"/>
                    <field name="analytic_department_id" groups="base.group_system"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- crm.team form: team type after user_id -->
    <record id="view_crm_team_form_team_type" model="ir.ui.view">
        <field name="name">crm.team.form.team_type</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_team_type"/>
            </xpath>
        </field>
    </record>

    <!-- crm.team list: project state column -->
    <record id="view_crm_team_list_project_state" model="ir.ui.view">
        <field name="name">crm.team.list.numo.project.fields</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_tree"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_project_state" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- crm.team list: team type column -->
    <record id="view_crm_team_list_team_type" model="ir.ui.view">
        <field name="name">crm.team.list.team_type</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_tree"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_team_type"/>
            </xpath>
        </field>
    </record>

</odoo>
