<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Team leaders see all leads in teams they lead -->
    <record id="rule_crm_lead_team_leader" model="ir.rule">
        <field name="name">CRM Lead: Team Leader sees team leads</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="domain_force">[('team_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Salespeople and team leaders see only their own teams -->
    <record id="rule_crm_team_own_teams" model="ir.rule">
        <field name="name">CRM Team: See own teams only</field>
        <field name="model_id" ref="sales_team.model_crm_team"/>
        <field name="domain_force">['|', ('member_ids', 'in', [user.id]), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Tighten the standard "Personal Leads" rule: drop the (user_id=False)
         clause so Sales Agents no longer see unassigned leads. Agents now
         see only leads explicitly assigned to them. Team leaders still see
         their team's leads via rule_crm_lead_team_leader above. -->
    <record id="crm.crm_rule_personal_lead" model="ir.rule">
        <field name="name">Personal Leads</field>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>

</odoo>
