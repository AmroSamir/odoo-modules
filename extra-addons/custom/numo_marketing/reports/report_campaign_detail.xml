<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_campaign_detail">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="data" t-value="doc._get_report_data()"/>
                <t t-set="kpis" t-value="data['kpis']"/>
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a2e;">

                        <!-- Header -->
                        <div style="border-bottom: 3px solid #0984e3; padding-bottom: 16px; margin-bottom: 24px;">
                            <h1 style="font-size: 28px; font-weight: 700; color: #1a1a2e; margin: 0;">
                                Campaign Performance Report
                            </h1>
                            <p style="font-size: 14px; color: #636e72; margin: 6px 0 0 0;">
                                <t t-esc="data['report'].name"/> |
                                <t t-esc="data['period_label']"/>
                            </p>
                        </div>

                        <!-- Summary KPIs -->
                        <div style="display: flex; gap: 12px; margin-bottom: 24px;">
                            <div style="flex: 1; background: linear-gradient(135deg, #0984e3, #74b9ff); border-radius: 8px; padding: 14px; color: white;">
                                <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; margin: 0; opacity: 0.85;">Spend</p>
                                <p style="font-size: 20px; font-weight: 700; margin: 4px 0 0 0;">
                                    <t t-esc="'{:,.2f}'.format(kpis['total_spend'])"/>
                                </p>
                            </div>
                            <div style="flex: 1; background: linear-gradient(135deg, #00b894, #55efc4); border-radius: 8px; padding: 14px; color: white;">
                                <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; margin: 0; opacity: 0.85;">Revenue</p>
                                <p style="font-size: 20px; font-weight: 700; margin: 4px 0 0 0;">
                                    <t t-esc="'{:,.2f}'.format(kpis['total_revenue'])"/>
                                </p>
                            </div>
                            <div style="flex: 1; background: linear-gradient(135deg, #6c5ce7, #a29bfe); border-radius: 8px; padding: 14px; color: white;">
                                <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; margin: 0; opacity: 0.85;">Leads</p>
                                <p style="font-size: 20px; font-weight: 700; margin: 4px 0 0 0;">
                                    <t t-esc="'{:,}'.format(kpis['total_leads'])"/>
                                </p>
                            </div>
                            <div style="flex: 1; background: linear-gradient(135deg, #e17055, #fab1a0); border-radius: 8px; padding: 14px; color: white;">
                                <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; margin: 0; opacity: 0.85;">ROAS</p>
                                <p style="font-size: 20px; font-weight: 700; margin: 4px 0 0 0;">
                                    <t t-esc="'{:.2f}'.format(kpis['roas'])"/>x
                                </p>
                            </div>
                        </div>

                        <!-- Campaign Performance Table -->
                        <t t-if="data['top_campaigns']">
                            <h2 style="font-size: 18px; font-weight: 600; color: #1a1a2e; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid #dfe6e9;">
                                Campaign Breakdown
                            </h2>
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 11px;">
                                <thead>
                                    <tr style="background: #1a1a2e; color: white;">
                                        <th style="padding: 8px 10px; text-align: left; border-radius: 6px 0 0 0;">Campaign</th>
                                        <th style="padding: 8px 10px; text-align: left;">Platform</th>
                                        <th style="padding: 8px 10px; text-align: left;">Project</th>
                                        <th style="padding: 8px 10px; text-align: right;">Spend</th>
                                        <th style="padding: 8px 10px; text-align: right;">Revenue</th>
                                        <th style="padding: 8px 10px; text-align: right;">Leads</th>
                                        <th style="padding: 8px 10px; text-align: right;">Won</th>
                                        <th style="padding: 8px 10px; text-align: right;">CPL</th>
                                        <th style="padding: 8px 10px; text-align: right;">ROAS</th>
                                        <th style="padding: 8px 10px; text-align: right; border-radius: 0 6px 0 0;">CTR%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="data['top_campaigns']" t-as="c">
                                        <tr t-attf-style="background: #{c_odd and '#f8f9fa' or '#ffffff'};">
                                            <td style="padding: 7px 10px; font-weight: 600; max-width: 160px; overflow: hidden; text-overflow: ellipsis;">
                                                <t t-esc="c['name']"/>
                                            </td>
                                            <td style="padding: 7px 10px;"><t t-esc="c['platform']"/></td>
                                            <td style="padding: 7px 10px;"><t t-esc="c['project']"/></td>
                                            <td style="padding: 7px 10px; text-align: right;"><t t-esc="'{:,.2f}'.format(c['spend'])"/></td>
                                            <td style="padding: 7px 10px; text-align: right;"><t t-esc="'{:,.2f}'.format(c['revenue'])"/></td>
                                            <td style="padding: 7px 10px; text-align: right;"><t t-esc="'{:,}'.format(c['leads'])"/></td>
                                            <td style="padding: 7px 10px; text-align: right;"><t t-esc="'{:,}'.format(c['won'])"/></td>
                                            <td style="padding: 7px 10px; text-align: right;"><t t-esc="'{:,.2f}'.format(c['cpl'])"/></td>
                                            <td style="padding: 7px 10px; text-align: right; font-weight: 600;">
                                                <t t-esc="'{:.2f}'.format(c['roas'])"/>x
                                            </td>
                                            <td style="padding: 7px 10px; text-align: right;"><t t-esc="'{:.2f}'.format(c['ctr'])"/>%</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Additional Metrics -->
                        <div style="display: flex; gap: 16px; margin-bottom: 24px;">
                            <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 14px;">
                                <p style="font-size: 11px; color: #636e72; text-transform: uppercase; margin: 0;">Impressions</p>
                                <p style="font-size: 18px; font-weight: 700; color: #1a1a2e; margin: 4px 0 0 0;">
                                    <t t-esc="'{:,}'.format(kpis['total_impressions'])"/>
                                </p>
                            </div>
                            <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 14px;">
                                <p style="font-size: 11px; color: #636e72; text-transform: uppercase; margin: 0;">Clicks</p>
                                <p style="font-size: 18px; font-weight: 700; color: #1a1a2e; margin: 4px 0 0 0;">
                                    <t t-esc="'{:,}'.format(kpis['total_clicks'])"/>
                                </p>
                            </div>
                            <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 14px;">
                                <p style="font-size: 11px; color: #636e72; text-transform: uppercase; margin: 0;">CTR</p>
                                <p style="font-size: 18px; font-weight: 700; color: #1a1a2e; margin: 4px 0 0 0;">
                                    <t t-esc="'{:.2f}'.format(kpis['ctr'])"/>%
                                </p>
                            </div>
                            <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 14px;">
                                <p style="font-size: 11px; color: #636e72; text-transform: uppercase; margin: 0;">CPC</p>
                                <p style="font-size: 18px; font-weight: 700; color: #1a1a2e; margin: 4px 0 0 0;">
                                    <t t-esc="'{:,.2f}'.format(kpis['cpc'])"/> SAR
                                </p>
                            </div>
                        </div>

                        <!-- Project ROI Table -->
                        <t t-if="data['project_breakdown']">
                            <h2 style="font-size: 18px; font-weight: 600; color: #1a1a2e; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid #dfe6e9;">
                                Project ROI
                            </h2>
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 12px;">
                                <thead>
                                    <tr style="background: #0984e3; color: white;">
                                        <th style="padding: 8px 12px; text-align: left; border-radius: 6px 0 0 0;">Project</th>
                                        <th style="padding: 8px 12px; text-align: right;">Spend (SAR)</th>
                                        <th style="padding: 8px 12px; text-align: right;">Revenue (SAR)</th>
                                        <th style="padding: 8px 12px; text-align: right;">Profit (SAR)</th>
                                        <th style="padding: 8px 12px; text-align: right;">Leads</th>
                                        <th style="padding: 8px 12px; text-align: right; border-radius: 0 6px 0 0;">ROAS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="data['project_breakdown']" t-as="proj">
                                        <tr t-attf-style="background: #{proj_odd and '#f8f9fa' or '#ffffff'};">
                                            <td style="padding: 7px 12px; font-weight: 600;"><t t-esc="proj['project']"/></td>
                                            <td style="padding: 7px 12px; text-align: right;"><t t-esc="'{:,.2f}'.format(proj['spend'])"/></td>
                                            <td style="padding: 7px 12px; text-align: right;"><t t-esc="'{:,.2f}'.format(proj['revenue'])"/></td>
                                            <td style="padding: 7px 12px; text-align: right;"
                                                t-attf-style="color: #{proj['profit'] >= 0 and '#00b894' or '#d63031'}; font-weight: 600;">
                                                <t t-esc="'{:,.2f}'.format(proj['profit'])"/>
                                            </td>
                                            <td style="padding: 7px 12px; text-align: right;"><t t-esc="'{:,}'.format(proj['leads'])"/></td>
                                            <td style="padding: 7px 12px; text-align: right; font-weight: 600;">
                                                <t t-esc="'{:.2f}'.format(proj['roas'])"/>x
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Footer -->
                        <div style="margin-top: 24px; padding-top: 12px; border-top: 1px solid #dfe6e9; font-size: 10px; color: #b2bec3; text-align: center;">
                            Generated by Numo Marketing Analytics |
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
