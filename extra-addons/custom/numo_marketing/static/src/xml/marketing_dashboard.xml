<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="numo_marketing.MarketingDashboard">
        <div class="o_action numo_mkt_dashboard">
            <!-- Loading State -->
            <t t-if="state.loading">
                <div class="numo_mkt_loading">
                    <div class="spinner-border text-primary" role="status"/>
                    <p class="mt-3" t-esc="T('loading')"/>
                </div>
            </t>

            <!-- Error State -->
            <t t-if="!state.loading and state.error">
                <div class="numo_mkt_loading">
                    <i class="fa fa-exclamation-triangle fa-3x text-danger"/>
                    <p class="mt-3 text-danger" t-esc="state.error"/>
                    <button class="btn btn-sm btn-primary mt-2" t-on-click="onResetFilters">Retry</button>
                </div>
            </t>

            <t t-if="!state.loading and state.data and !state.error">
                <!-- Header -->
                <div class="numo_mkt_header">
                    <h2 class="numo_mkt_title" t-esc="T('title')"/>
                    <button class="btn btn-sm btn-outline-primary" t-on-click="openSpendList">
                        <i class="fa fa-list me-1"/>
                        <t t-esc="T('total_spend')"/>
                    </button>
                </div>

                <!-- Filters Bar -->
                <div class="numo_mkt_filters">
                    <div class="numo_mkt_filter_group">
                        <label t-esc="T('date_from')"/>
                        <input type="date" class="form-control form-control-sm"
                               t-att-value="state.filters.date_from"
                               t-on-change="onDateFromChange"/>
                    </div>
                    <div class="numo_mkt_filter_group">
                        <label t-esc="T('date_to')"/>
                        <input type="date" class="form-control form-control-sm"
                               t-att-value="state.filters.date_to"
                               t-on-change="onDateToChange"/>
                    </div>
                    <div class="numo_mkt_filter_group">
                        <label t-esc="T('platform')"/>
                        <select class="form-select form-select-sm"
                                t-on-change="onPlatformChange">
                            <option value="" t-esc="T('all')"/>
                            <t t-foreach="state.data.filter_options.platforms" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value"
                                        t-att-selected="state.filters.platform === opt.value"
                                        t-esc="opt.label"/>
                            </t>
                        </select>
                    </div>
                    <div class="numo_mkt_filter_group">
                        <label t-esc="T('project')"/>
                        <select class="form-select form-select-sm"
                                t-on-change="onProjectChange">
                            <option value="" t-esc="T('all')"/>
                            <t t-foreach="state.data.filter_options.projects" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value"
                                        t-att-selected="'' + state.filters.project_id === '' + opt.value"
                                        t-esc="opt.label"/>
                            </t>
                        </select>
                    </div>
                    <div class="numo_mkt_filter_group">
                        <label t-esc="T('campaign')"/>
                        <select class="form-select form-select-sm"
                                t-on-change="onCampaignChange">
                            <option value="" t-esc="T('all')"/>
                            <t t-foreach="state.data.filter_options.campaigns" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value"
                                        t-att-selected="'' + state.filters.campaign_id === '' + opt.value"
                                        t-esc="opt.label"/>
                            </t>
                        </select>
                    </div>
                    <div class="numo_mkt_filter_actions">
                        <button class="btn btn-sm btn-primary" t-on-click="onApplyFilters" t-esc="T('apply')"/>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="onResetFilters" t-esc="T('reset')"/>
                    </div>
                </div>

                <!-- KPI Cards -->
                <div class="numo_mkt_kpi_grid">
                    <!-- Spend -->
                    <div class="numo_mkt_kpi_card numo_kpi_spend">
                        <div class="numo_kpi_icon"><i class="fa fa-money"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatCurrency(state.data.kpis.total_spend)"/>
                            <div class="numo_kpi_label" t-esc="T('total_spend')"/>
                        </div>
                        <div class="numo_kpi_unit" t-esc="T('sar')"/>
                    </div>
                    <!-- Revenue -->
                    <div class="numo_mkt_kpi_card numo_kpi_revenue">
                        <div class="numo_kpi_icon"><i class="fa fa-line-chart"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatCurrency(state.data.kpis.total_revenue)"/>
                            <div class="numo_kpi_label" t-esc="T('total_revenue')"/>
                        </div>
                        <div class="numo_kpi_unit" t-esc="T('sar')"/>
                    </div>
                    <!-- Profit -->
                    <div class="numo_mkt_kpi_card numo_kpi_profit">
                        <div class="numo_kpi_icon"><i class="fa fa-trophy"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatCurrency(state.data.kpis.profit)"/>
                            <div class="numo_kpi_label" t-esc="T('profit')"/>
                        </div>
                        <div class="numo_kpi_unit" t-esc="T('sar')"/>
                    </div>
                    <!-- ROAS -->
                    <div class="numo_mkt_kpi_card numo_kpi_roas">
                        <div class="numo_kpi_icon"><i class="fa fa-refresh"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatNumber(state.data.kpis.roas)"/>
                            <div class="numo_kpi_label" t-esc="T('roas')"/>
                        </div>
                        <div class="numo_kpi_unit">x</div>
                    </div>
                    <!-- Leads -->
                    <div class="numo_mkt_kpi_card numo_kpi_leads">
                        <div class="numo_kpi_icon"><i class="fa fa-users"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatNumber(state.data.kpis.total_leads)"/>
                            <div class="numo_kpi_label" t-esc="T('total_leads')"/>
                        </div>
                    </div>
                    <!-- Won -->
                    <div class="numo_mkt_kpi_card numo_kpi_won">
                        <div class="numo_kpi_icon"><i class="fa fa-check-circle"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatNumber(state.data.kpis.total_won)"/>
                            <div class="numo_kpi_label" t-esc="T('total_won')"/>
                        </div>
                    </div>
                    <!-- CPL -->
                    <div class="numo_mkt_kpi_card numo_kpi_cpl">
                        <div class="numo_kpi_icon"><i class="fa fa-tag"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatCurrency(state.data.kpis.cpl)"/>
                            <div class="numo_kpi_label" t-esc="T('cpl')"/>
                        </div>
                        <div class="numo_kpi_unit" t-esc="T('sar')"/>
                    </div>
                    <!-- Lead to Sale -->
                    <div class="numo_mkt_kpi_card numo_kpi_l2s">
                        <div class="numo_kpi_icon"><i class="fa fa-exchange"/></div>
                        <div class="numo_kpi_content">
                            <div class="numo_kpi_value" t-esc="formatPercent(state.data.kpis.lead_to_sale)"/>
                            <div class="numo_kpi_label" t-esc="T('lead_to_sale')"/>
                        </div>
                    </div>
                </div>

                <!-- Secondary KPIs Row -->
                <div class="numo_mkt_kpi_secondary">
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('impressions')"/>
                        <span class="numo_mini_value" t-esc="formatNumber(state.data.kpis.total_impressions)"/>
                    </div>
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('clicks')"/>
                        <span class="numo_mini_value" t-esc="formatNumber(state.data.kpis.total_clicks)"/>
                    </div>
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('ctr')"/>
                        <span class="numo_mini_value" t-esc="formatPercent(state.data.kpis.ctr)"/>
                    </div>
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('cpa')"/>
                        <span class="numo_mini_value"><t t-esc="formatCurrency(state.data.kpis.cpa)"/> <small t-esc="T('sar')"/></span>
                    </div>
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('conversion_rate')"/>
                        <span class="numo_mini_value" t-esc="formatPercent(state.data.kpis.conversion_rate)"/>
                    </div>
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('qualified')"/>
                        <span class="numo_mini_value" t-esc="formatNumber(state.data.kpis.total_qualified)"/>
                    </div>
                    <div class="numo_mkt_kpi_mini">
                        <span class="numo_mini_label" t-esc="T('lost')"/>
                        <span class="numo_mini_value" t-esc="formatNumber(state.data.kpis.total_lost)"/>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="numo_mkt_charts_row">
                    <div class="numo_mkt_chart_card numo_chart_wide">
                        <canvas t-ref="spendRevenueChart"/>
                    </div>
                    <div class="numo_mkt_chart_card numo_chart_narrow">
                        <canvas t-ref="platformChart"/>
                    </div>
                </div>

                <!-- Project Chart -->
                <div class="numo_mkt_charts_row">
                    <div class="numo_mkt_chart_card numo_chart_full">
                        <canvas t-ref="projectChart"/>
                    </div>
                </div>

                <!-- Top Campaigns Table -->
                <div class="numo_mkt_table_card">
                    <h4 t-esc="T('top_campaigns')"/>
                    <t t-if="state.data.top_campaigns.length === 0">
                        <p class="text-muted" t-esc="T('no_data')"/>
                    </t>
                    <t t-if="state.data.top_campaigns.length > 0">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th t-esc="T('name')"/>
                                        <th t-esc="T('platform')"/>
                                        <th t-esc="T('project')"/>
                                        <th class="text-end" t-esc="T('spend')"/>
                                        <th class="text-end" t-esc="T('leads')"/>
                                        <th class="text-end" t-esc="T('won')"/>
                                        <th class="text-end" t-esc="T('revenue')"/>
                                        <th class="text-end" t-esc="T('cpl')"/>
                                        <th class="text-end" t-esc="T('roas')"/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.data.top_campaigns" t-as="c" t-key="c.id">
                                        <tr>
                                            <td t-esc="c_index + 1"/>
                                            <td t-esc="c.name"/>
                                            <td t-esc="c.platform"/>
                                            <td t-esc="c.project"/>
                                            <td class="text-end"><t t-esc="formatCurrency(c.spend)"/></td>
                                            <td class="text-end" t-esc="c.leads"/>
                                            <td class="text-end" t-esc="c.won"/>
                                            <td class="text-end"><t t-esc="formatCurrency(c.revenue)"/></td>
                                            <td class="text-end"><t t-esc="formatCurrency(c.cpl)"/></td>
                                            <td class="text-end" t-esc="c.roas"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </t>

            <!-- No Data State -->
            <t t-if="!state.loading and !state.data and !state.error">
                <div class="numo_mkt_loading">
                    <i class="fa fa-bar-chart fa-3x text-muted"/>
                    <p class="mt-3 text-muted" t-esc="T('no_data')"/>
                </div>
            </t>
        </div>
    </t>
</templates>
