<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="numo_marketing.MarketingDashboard">
    <div class="numo_dashboard">

        <!-- ============================================================ -->
        <!-- Header + Filter Bar (single row) -->
        <!-- ============================================================ -->
        <div class="numo_header_bar">
            <div class="numo_template_tabs">
                <button t-attf-class="numo_tab #{state.activeTemplate === 'all' ? 'active' : ''}"
                        t-on-click="() => this.setTemplate('all')">All</button>
                <button t-attf-class="numo_tab #{state.activeTemplate === 'executive' ? 'active' : ''}"
                        t-on-click="() => this.setTemplate('executive')">Executive</button>
                <button t-attf-class="numo_tab #{state.activeTemplate === 'channel' ? 'active' : ''}"
                        t-on-click="() => this.setTemplate('channel')">Channel</button>
                <button t-attf-class="numo_tab #{state.activeTemplate === 'project_roi' ? 'active' : ''}"
                        t-on-click="() => this.setTemplate('project_roi')">Project ROI</button>
                <button t-attf-class="numo_tab #{state.activeTemplate === 'funnel' ? 'active' : ''}"
                        t-on-click="() => this.setTemplate('funnel')">Funnel</button>
            </div>
            <div class="numo_filters_inline">
                <div class="numo_filter_group">
                    <label><t t-esc="T('date_from')"/></label>
                    <input type="date" t-att-value="state.filters.date_from"
                           t-on-change="(ev) => this.onFilterChange('date_from', ev)"/>
                </div>
                <div class="numo_filter_group">
                    <label><t t-esc="T('date_to')"/></label>
                    <input type="date" t-att-value="state.filters.date_to"
                           t-on-change="(ev) => this.onFilterChange('date_to', ev)"/>
                </div>
                <div class="numo_filter_group">
                    <label><t t-esc="T('platform')"/></label>
                    <select t-on-change="(ev) => this.onFilterChange('platform', ev)">
                        <option value=""><t t-esc="T('all')"/></option>
                        <t t-foreach="state.data?.filter_options?.platforms || []" t-as="p" t-key="p.value">
                            <option t-att-value="p.value" t-att-selected="state.filters.platform === p.value">
                                <t t-esc="p.label"/>
                            </option>
                        </t>
                    </select>
                </div>
                <div class="numo_filter_group">
                    <label><t t-esc="T('project')"/></label>
                    <select t-on-change="(ev) => this.onFilterChange('project_id', ev)">
                        <option value=""><t t-esc="T('all')"/></option>
                        <t t-foreach="state.data?.filter_options?.projects || []" t-as="p" t-key="p.value">
                            <option t-att-value="p.value" t-att-selected="state.filters.project_id === p.value">
                                <t t-esc="p.label"/>
                            </option>
                        </t>
                    </select>
                </div>
                <div class="numo_filter_group numo_filter_compare">
                    <label>
                        <input type="checkbox" t-att-checked="state.filters.compare"
                               t-on-change="(ev) => this.onCompareToggle(ev)"/>
                        <t t-esc="T('compare')"/>
                    </label>
                </div>
                <div class="numo_filter_actions">
                    <button class="numo_btn numo_btn_primary" t-on-click="applyFilters">
                        <t t-esc="T('apply')"/>
                    </button>
                    <button class="numo_btn numo_btn_secondary" t-on-click="resetFilters">
                        <t t-esc="T('reset')"/>
                    </button>
                </div>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- Loading State -->
        <!-- ============================================================ -->
        <div t-if="state.loading" class="numo_loading">
            <div class="numo_spinner"/>
            <span><t t-esc="T('loading')"/></span>
        </div>

        <!-- ============================================================ -->
        <!-- No Data State -->
        <!-- ============================================================ -->
        <div t-elif="!state.data || !kpis.total_spend" class="numo_empty">
            <i class="fa fa-bar-chart fa-3x"/>
            <p><t t-esc="T('no_data')"/></p>
        </div>

        <!-- ============================================================ -->
        <!-- Dashboard Content -->
        <!-- ============================================================ -->
        <div t-else="" class="numo_content">

            <!-- KPI Cards Row 1: Primary metrics -->
            <div class="numo_kpi_grid">
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'total_spend'"/>
                    <t t-set="kpiLabel" t-value="T('total_spend')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.total_spend, 'currency')"/>
                    <t t-set="kpiIcon" t-value="'fa-money'"/>
                    <t t-set="kpiColor" t-value="'indigo'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'total_revenue'"/>
                    <t t-set="kpiLabel" t-value="T('total_revenue')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.total_revenue, 'currency')"/>
                    <t t-set="kpiIcon" t-value="'fa-line-chart'"/>
                    <t t-set="kpiColor" t-value="'emerald'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'profit'"/>
                    <t t-set="kpiLabel" t-value="T('profit')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.profit, 'currency')"/>
                    <t t-set="kpiIcon" t-value="'fa-trophy'"/>
                    <t t-set="kpiColor" t-value="kpis.profit >= 0 ? 'emerald' : 'red'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'roas'"/>
                    <t t-set="kpiLabel" t-value="T('roas')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.roas, 'ratio')"/>
                    <t t-set="kpiIcon" t-value="'fa-refresh'"/>
                    <t t-set="kpiColor" t-value="kpis.roas >= 2 ? 'emerald' : (kpis.roas >= 1 ? 'amber' : 'red')"/>
                </t>
            </div>

            <!-- KPI Cards Row 2: Secondary metrics -->
            <div class="numo_kpi_grid numo_kpi_secondary">
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'total_leads'"/>
                    <t t-set="kpiLabel" t-value="T('total_leads')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.total_leads, 'compact')"/>
                    <t t-set="kpiIcon" t-value="'fa-users'"/>
                    <t t-set="kpiColor" t-value="'violet'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'total_won'"/>
                    <t t-set="kpiLabel" t-value="T('total_won')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.total_won, 'compact')"/>
                    <t t-set="kpiIcon" t-value="'fa-check-circle'"/>
                    <t t-set="kpiColor" t-value="'emerald'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'cpl'"/>
                    <t t-set="kpiLabel" t-value="T('cpl')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.cpl, 'currency')"/>
                    <t t-set="kpiIcon" t-value="'fa-tag'"/>
                    <t t-set="kpiColor" t-value="'amber'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'ctr'"/>
                    <t t-set="kpiLabel" t-value="T('ctr')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.ctr, 'percent')"/>
                    <t t-set="kpiIcon" t-value="'fa-mouse-pointer'"/>
                    <t t-set="kpiColor" t-value="'cyan'"/>
                </t>
                <t t-call="numo_marketing.KpiCard">
                    <t t-set="kpiKey" t-value="'lead_to_sale'"/>
                    <t t-set="kpiLabel" t-value="T('lead_to_sale')"/>
                    <t t-set="kpiValue" t-value="fmt(kpis.lead_to_sale, 'percent')"/>
                    <t t-set="kpiIcon" t-value="'fa-exchange'"/>
                    <t t-set="kpiColor" t-value="'pink'"/>
                </t>
            </div>

            <!-- Charts Grid -->
            <div class="numo_charts_grid">
                <!-- Spend vs Revenue Trend -->
                <div class="numo_card numo_card_wide">
                    <div class="numo_card_header">
                        <h3><t t-esc="T('spend_vs_revenue')"/></h3>
                    </div>
                    <div class="numo_chart_container">
                        <canvas t-ref="trendChart"/>
                    </div>
                </div>

                <!-- Platform Breakdown -->
                <div class="numo_card">
                    <div class="numo_card_header">
                        <h3><t t-esc="T('platform_spend')"/></h3>
                    </div>
                    <div class="numo_chart_container numo_chart_doughnut">
                        <canvas t-ref="platformChart"/>
                    </div>
                </div>

                <!-- Channel Contribution -->
                <div class="numo_card">
                    <div class="numo_card_header">
                        <h3><t t-esc="T('channel_contribution')"/></h3>
                    </div>
                    <div class="numo_chart_container">
                        <canvas t-ref="contributionChart"/>
                    </div>
                </div>

                <!-- Project Performance -->
                <div class="numo_card numo_card_wide">
                    <div class="numo_card_header">
                        <h3><t t-esc="T('project_performance')"/></h3>
                    </div>
                    <div class="numo_chart_container">
                        <canvas t-ref="projectChart"/>
                    </div>
                </div>
            </div>

            <!-- Funnel -->
            <div class="numo_card numo_card_full">
                <div class="numo_card_header">
                    <h3><t t-esc="T('funnel')"/></h3>
                </div>
                <div t-ref="funnelContainer" class="numo_funnel_wrapper"/>
            </div>

            <!-- Top Campaigns Table -->
            <div class="numo_card numo_card_full">
                <div class="numo_card_header">
                    <h3><t t-esc="T('top_campaigns')"/></h3>
                </div>
                <div class="numo_table_wrapper">
                    <table class="numo_table">
                        <thead>
                            <tr>
                                <th><t t-esc="T('name')"/></th>
                                <th><t t-esc="T('platform')"/></th>
                                <th><t t-esc="T('project')"/></th>
                                <th class="numo_num"><t t-esc="T('spend')"/></th>
                                <th class="numo_num"><t t-esc="T('revenue')"/></th>
                                <th class="numo_num"><t t-esc="T('leads')"/></th>
                                <th class="numo_num"><t t-esc="T('ctr')"/></th>
                                <th class="numo_num"><t t-esc="T('cpl')"/></th>
                                <th class="numo_num"><t t-esc="T('roas')"/></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data?.top_campaigns || []" t-as="camp" t-key="camp.id">
                                <tr>
                                    <td class="numo_campaign_name"><t t-esc="camp.name"/></td>
                                    <td><span class="numo_platform_badge"><t t-esc="camp.platform"/></span></td>
                                    <td><t t-esc="camp.project || '—'"/></td>
                                    <td class="numo_num"><t t-esc="fmt(camp.spend, 'currency')"/></td>
                                    <td class="numo_num"><t t-esc="fmt(camp.revenue, 'currency')"/></td>
                                    <td class="numo_num"><t t-esc="camp.leads"/></td>
                                    <td class="numo_num"><t t-esc="fmt(camp.ctr, 'percent')"/></td>
                                    <td class="numo_num"><t t-esc="fmt(camp.cpl, 'currency')"/></td>
                                    <td class="numo_num">
                                        <span t-attf-class="numo_roas_badge #{camp.roas >= 2 ? 'good' : (camp.roas >= 1 ? 'ok' : 'bad')}">
                                            <t t-esc="fmt(camp.roas, 'ratio')"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</t>

<!-- ============================================================ -->
<!-- KPI Card Sub-template -->
<!-- ============================================================ -->
<t t-name="numo_marketing.KpiCard">
    <div t-attf-class="numo_kpi_card numo_kpi_#{kpiColor}">
        <div class="numo_kpi_icon">
            <i t-attf-class="fa #{kpiIcon}"/>
        </div>
        <div class="numo_kpi_body">
            <span class="numo_kpi_label"><t t-esc="kpiLabel"/></span>
            <span class="numo_kpi_value"><t t-esc="kpiValue"/></span>
            <div t-if="hasComparison and comparison[kpiKey]"
                 t-attf-class="numo_kpi_delta #{deltaClass(kpiKey)}">
                <span class="numo_delta_icon"><t t-esc="deltaIcon(kpiKey)"/></span>
                <span class="numo_delta_pct"><t t-esc="deltaPct(kpiKey)"/></span>
            </div>
        </div>
    </div>
</t>

</templates>
