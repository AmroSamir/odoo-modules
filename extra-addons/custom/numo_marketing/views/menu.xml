<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Root App Menu -->
    <!-- ============================================================ -->
    <menuitem id="menu_marketing_analytics_root"
              name="Marketing Analytics"
              web_icon="numo_marketing,static/description/icon.png"
              sequence="45"/>

    <!-- ============================================================ -->
    <!-- Dashboard -->
    <!-- ============================================================ -->
    <menuitem id="menu_marketing_dashboard"
              name="Dashboard"
              parent="menu_marketing_analytics_root"
              action="action_marketing_dashboard"
              sequence="10"/>

    <!-- ============================================================ -->
    <!-- Data Section -->
    <!-- ============================================================ -->
    <menuitem id="menu_marketing_data"
              name="Data"
              parent="menu_marketing_analytics_root"
              sequence="20"/>

    <menuitem id="menu_marketing_campaigns"
              name="Campaigns"
              parent="menu_marketing_data"
              action="action_marketing_campaign"
              sequence="10"/>

    <menuitem id="menu_marketing_metrics"
              name="Metrics"
              parent="menu_marketing_data"
              action="action_marketing_metric"
              sequence="20"/>

    <!-- ============================================================ -->
    <!-- Reports Section -->
    <!-- ============================================================ -->
    <menuitem id="menu_marketing_reports"
              name="Reports"
              parent="menu_marketing_analytics_root"
              sequence="30"/>

    <menuitem id="menu_marketing_report_templates"
              name="Report Templates"
              parent="menu_marketing_reports"
              action="action_marketing_report"
              sequence="10"
              groups="numo_marketing.group_marketing_manager"/>

    <!-- ============================================================ -->
    <!-- Configuration Section (Manager only) -->
    <!-- ============================================================ -->
    <menuitem id="menu_marketing_config"
              name="Configuration"
              parent="menu_marketing_analytics_root"
              groups="numo_marketing.group_marketing_manager"
              sequence="90"/>

    <menuitem id="menu_marketing_accounts"
              name="Ad Accounts"
              parent="menu_marketing_config"
              action="action_marketing_account"
              sequence="10"/>

    <menuitem id="menu_marketing_sync_log"
              name="Sync Logs"
              parent="menu_marketing_config"
              action="action_marketing_sync_log"
              sequence="20"/>

    <menuitem id="menu_marketing_manual_entry"
              name="Manual Data Entry"
              parent="menu_marketing_config"
              action="numo_marketing.action_manual_entry_wizard"
              sequence="30"/>

</odoo>
