<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="numo_ad_sync_log_list" model="ir.ui.view">
        <field name="name">numo.ad.sync.log.list</field>
        <field name="model">numo.ad.sync.log</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc">
                <field name="create_date"/>
                <field name="platform"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="status" widget="badge"/>
                <field name="records_fetched"/>
                <field name="records_created"/>
                <field name="records_updated"/>
                <field name="duration_seconds"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="numo_ad_sync_log_form" model="ir.ui.view">
        <field name="name">numo.ad.sync.log.form</field>
        <field name="model">numo.ad.sync.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="platform"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="status" widget="badge"/>
                        </group>
                        <group>
                            <field name="records_fetched"/>
                            <field name="records_created"/>
                            <field name="records_updated"/>
                            <field name="duration_seconds"/>
                        </group>
                    </group>
                    <group string="Error Details" invisible="status != 'error'">
                        <field name="error_message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ad_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Log</field>
        <field name="res_model">numo.ad.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
