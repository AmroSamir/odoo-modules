<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="numo_campaign_mapping_list" model="ir.ui.view">
        <field name="name">numo.campaign.mapping.list</field>
        <field name="model">numo.campaign.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="campaign_id"/>
                <field name="project_analytic_id"/>
                <field name="platform"/>
                <field name="product_id" optional="show"/>
                <field name="name_pattern" optional="show"/>
                <field name="active" column_invisible="1"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="numo_campaign_mapping_form" model="ir.ui.view">
        <field name="name">numo.campaign.mapping.form</field>
        <field name="model">numo.campaign.mapping</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="campaign_id"/>
                            <field name="project_analytic_id"/>
                            <field name="platform"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="name_pattern"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Optional notes about this mapping..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_campaign_mapping" model="ir.actions.act_window">
        <field name="name">Campaign Mappings</field>
        <field name="res_model">numo.campaign.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
