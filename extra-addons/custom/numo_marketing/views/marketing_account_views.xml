<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Account: Form View -->
    <!-- ============================================================ -->
    <record id="view_marketing_account_form" model="ir.ui.view">
        <field name="name">numo.marketing.account.form</field>
        <field name="model">numo.marketing.account</field>
        <field name="arch" type="xml">
            <form string="Ad Platform Account">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            class="btn-secondary"
                            icon="fa-plug"/>
                    <button name="action_sync_now"
                            string="Sync Now (Last 7 Days)"
                            type="object"
                            class="btn-primary"
                            icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Account Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="platform"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="last_sync_date"/>
                            <field name="last_sync_status"/>
                        </group>
                    </group>

                    <!-- Google Ads Credentials -->
                    <group string="Google Ads Credentials"
                           invisible="platform != 'google_ads'">
                        <group>
                            <field name="google_developer_token" password="True"/>
                            <field name="google_client_id"/>
                            <field name="google_client_secret" password="True"/>
                        </group>
                        <group>
                            <field name="google_refresh_token" password="True"/>
                            <field name="google_customer_id"
                                   placeholder="123-456-7890"/>
                        </group>
                    </group>

                    <!-- Meta Credentials -->
                    <group string="Meta Credentials"
                           invisible="platform != 'meta'">
                        <group>
                            <field name="meta_access_token" password="True"/>
                        </group>
                        <group>
                            <field name="meta_ad_account_id"
                                   placeholder="act_123456789"/>
                        </group>
                    </group>

                    <!-- TikTok Credentials -->
                    <group string="TikTok Credentials"
                           invisible="platform != 'tiktok'">
                        <group>
                            <field name="tiktok_access_token" password="True"/>
                        </group>
                        <group>
                            <field name="tiktok_advertiser_id"/>
                        </group>
                    </group>

                    <!-- Snapchat Credentials -->
                    <group string="Snapchat Credentials"
                           invisible="platform != 'snapchat'">
                        <group>
                            <field name="snapchat_client_id"/>
                            <field name="snapchat_client_secret" password="True"/>
                        </group>
                        <group>
                            <field name="snapchat_refresh_token" password="True"/>
                            <field name="snapchat_ad_account_id"/>
                            <button name="action_authorize_snapchat"
                                    string="Authorize with Snapchat"
                                    type="object"
                                    class="btn-warning"
                                    icon="fa-snapchat"
                                    invisible="not snapchat_client_id or not snapchat_client_secret"/>
                        </group>
                    </group>

                    <!-- X (Twitter) Credentials -->
                    <group string="X (Twitter) Credentials"
                           invisible="platform != 'x_ads'">
                        <group>
                            <field name="x_consumer_key"/>
                            <field name="x_consumer_secret" password="True"/>
                            <field name="x_access_token" password="True"/>
                        </group>
                        <group>
                            <field name="x_access_secret" password="True"/>
                            <field name="x_ad_account_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Account: Tree View -->
    <!-- ============================================================ -->
    <record id="view_marketing_account_tree" model="ir.ui.view">
        <field name="name">numo.marketing.account.tree</field>
        <field name="model">numo.marketing.account</field>
        <field name="arch" type="xml">
            <list string="Ad Platform Accounts">
                <field name="name"/>
                <field name="platform"/>
                <field name="last_sync_date"/>
                <field name="last_sync_status" widget="badge"
                       decoration-success="last_sync_status == 'success'"
                       decoration-danger="last_sync_status == 'error'"
                       decoration-warning="last_sync_status == 'partial'"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Account: Search View -->
    <!-- ============================================================ -->
    <record id="view_marketing_account_search" model="ir.ui.view">
        <field name="name">numo.marketing.account.search</field>
        <field name="model">numo.marketing.account</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="platform"/>
                <filter string="Active" name="active"
                        domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Sync Error" name="sync_error"
                        domain="[('last_sync_status', '=', 'error')]"/>
                <filter string="Platform" name="group_platform"
                        context="{'group_by': 'platform'}"/>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Account: Action -->
    <!-- ============================================================ -->
    <record id="action_marketing_account" model="ir.actions.act_window">
        <field name="name">Ad Accounts</field>
        <field name="res_model">numo.marketing.account</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_marketing_account_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first ad platform account
            </p>
            <p>Connect Google Ads, Meta, TikTok, Snapchat, or X to start syncing campaign data.</p>
        </field>
    </record>

</odoo>
