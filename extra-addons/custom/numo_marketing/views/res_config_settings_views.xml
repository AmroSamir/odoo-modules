<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form_numo_marketing" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.numo_marketing</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Marketing Analytics" data-key="numo_marketing">

                    <block title="Google Ads" name="google_ads_settings">
                        <setting string="Google Ads Integration" help="Enable daily sync from Google Ads API">
                            <field name="numo_google_ads_enabled"/>
                            <div class="content-group" invisible="not numo_google_ads_enabled">
                                <div class="row mt16">
                                    <label for="numo_google_ads_developer_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_google_ads_developer_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_google_ads_client_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_google_ads_client_id" class="col-9 col-lg-6"/>
                                </div>
                                <div class="row">
                                    <label for="numo_google_ads_client_secret" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_google_ads_client_secret" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_google_ads_refresh_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_google_ads_refresh_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_google_ads_customer_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_google_ads_customer_id" class="col-9 col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Meta (Facebook / Instagram)" name="meta_settings">
                        <setting string="Meta Ads Integration" help="Enable daily sync from Meta Marketing API">
                            <field name="numo_meta_enabled"/>
                            <div class="content-group" invisible="not numo_meta_enabled">
                                <div class="row mt16">
                                    <label for="numo_meta_access_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_meta_access_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_meta_ad_account_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_meta_ad_account_id" class="col-9 col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="TikTok" name="tiktok_settings">
                        <setting string="TikTok Ads Integration" help="Enable daily sync from TikTok Marketing API">
                            <field name="numo_tiktok_enabled"/>
                            <div class="content-group" invisible="not numo_tiktok_enabled">
                                <div class="row mt16">
                                    <label for="numo_tiktok_access_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_tiktok_access_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_tiktok_advertiser_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_tiktok_advertiser_id" class="col-9 col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Snapchat" name="snapchat_settings">
                        <setting string="Snapchat Ads Integration" help="Enable daily sync from Snapchat Marketing API">
                            <field name="numo_snapchat_enabled"/>
                            <div class="content-group" invisible="not numo_snapchat_enabled">
                                <div class="row mt16">
                                    <label for="numo_snapchat_access_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_snapchat_access_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_snapchat_client_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_snapchat_client_id" class="col-9 col-lg-6"/>
                                </div>
                                <div class="row">
                                    <label for="numo_snapchat_client_secret" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_snapchat_client_secret" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_snapchat_refresh_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_snapchat_refresh_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_snapchat_ad_account_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_snapchat_ad_account_id" class="col-9 col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="X (Twitter)" name="x_settings">
                        <setting string="X Ads Integration" help="Enable daily sync from X Ads API">
                            <field name="numo_x_enabled"/>
                            <div class="content-group" invisible="not numo_x_enabled">
                                <div class="row mt16">
                                    <label for="numo_x_consumer_key" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_x_consumer_key" class="col-9 col-lg-6"/>
                                </div>
                                <div class="row">
                                    <label for="numo_x_consumer_secret" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_x_consumer_secret" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_x_access_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_x_access_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_x_access_secret" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_x_access_secret" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_x_bearer_token" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_x_bearer_token" class="col-9 col-lg-6" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="numo_x_ad_account_id" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="numo_x_ad_account_id" class="col-9 col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
