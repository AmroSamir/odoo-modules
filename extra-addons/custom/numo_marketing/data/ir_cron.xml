<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Daily CRM Metrics Update -->
    <record id="cron_update_crm_metrics" model="ir.cron">
        <field name="name">Marketing: Update CRM Metrics</field>
        <field name="model_id" ref="model_numo_campaign_spend"/>
        <field name="state">code</field>
        <field name="code">model._cron_update_crm_metrics()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>

        <field name="active">True</field>
    </record>

