<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Sync all ad accounts (daily at 03:00 AM) -->
    <record id="cron_sync_all_accounts" model="ir.cron">
        <field name="name">Marketing: Sync All Ad Accounts</field>
        <field name="model_id" ref="model_numo_marketing_account"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_all_accounts()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="False"/>
        <field name="priority">10</field>
    </record>

    <!-- Update CRM metrics on metrics (daily at 05:00 AM) -->
    <record id="cron_update_crm_metrics" model="ir.cron">
        <field name="name">Marketing: Update CRM Metrics</field>
        <field name="model_id" ref="model_numo_marketing_metric"/>
        <field name="state">code</field>
        <field name="code">model._cron_update_crm_metrics()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="priority">20</field>
    </record>

    <!-- Send scheduled reports (daily at 07:00 AM) -->
    <record id="cron_send_scheduled_reports" model="ir.cron">
        <field name="name">Marketing: Send Scheduled Reports</field>
        <field name="model_id" ref="model_numo_marketing_report"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_scheduled_reports()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="False"/>
        <field name="priority">30</field>
    </record>

</odoo>
