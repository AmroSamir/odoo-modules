<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Manual Spend Wizard: Form View -->
    <record id="numo_manual_spend_wizard_form" model="ir.ui.view">
        <field name="name">numo.manual.spend.wizard.form</field>
        <field name="model">numo.manual.spend.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Period">
                        <field name="date"/>
                        <field name="date_end"/>
                    </group>
                    <group string="Campaign">
                        <field name="platform"/>
                        <field name="campaign_id"/>
                        <field name="campaign_type"/>
                        <field name="medium_id"/>
                    </group>
                </group>
                <group string="Metrics">
                    <group>
                        <field name="spend_amount"/>
                        <field name="impressions"/>
                    </group>
                    <group>
                        <field name="clicks"/>
                        <field name="conversions_platform"/>
                    </group>
                </group>
                <group>
                    <field name="notes" placeholder="Optional notes..."/>
                </group>
                <footer>
                    <button name="action_create_spend" type="object"
                            string="Create Spend Record(s)" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Manual Spend Wizard: Action -->
    <record id="action_manual_spend_wizard" model="ir.actions.act_window">
        <field name="name">Manual Spend Entry</field>
        <field name="res_model">numo.manual.spend.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
