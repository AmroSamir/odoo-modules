<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="proofing_upload_wizard_form" model="ir.ui.view">
        <field name="name">proofing.upload.wizard.form</field>
        <field name="model">proofing.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload File">
                <group>
                    <field name="project_id" invisible="1"/>
                    <field name="file_id" invisible="1"/>
                    <!-- Single file: new version of existing file -->
                    <field name="file_data" filename="filename"
                           invisible="not file_id"/>
                    <field name="filename" invisible="1"/>
                    <field name="notes" placeholder="What changed in this version..."/>
                </group>
                <!-- Multi-file: new files -->
                <group string="Files" invisible="file_id">
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="file_data" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_upload" string="Upload" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
