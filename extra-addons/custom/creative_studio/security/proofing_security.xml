<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_proofing_user" model="res.groups">
        <field name="name">Creative Studio: User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_proofing_manager" model="res.groups">
        <field name="name">Creative Studio: Manager</field>
        <field name="implied_ids" eval="[(4, ref('creative_studio.group_proofing_user'))]"/>
    </record>

    <!-- Admins get Manager access by default -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('creative_studio.group_proofing_manager'))]"/>
    </record>
</odoo>
