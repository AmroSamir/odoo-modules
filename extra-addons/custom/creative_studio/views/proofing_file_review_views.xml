<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- File Review Tree View -->
    <record id="proofing_file_review_view_tree" model="ir.ui.view">
        <field name="name">proofing.file.review.tree</field>
        <field name="model">proofing.file.review</field>
        <field name="arch" type="xml">
            <list>
                <field name="file_id"/>
                <field name="step_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-info="state == 'in_review'"
                       decoration-warning="state == 'changes_requested'"
                       decoration-muted="state == 'not_started'"/>
                <field name="decision_summary" string="Approved"/>
            </list>
        </field>
    </record>

    <!-- File Review Form -->
    <record id="proofing_file_review_view_form" model="ir.ui.view">
        <field name="name">proofing.file.review.form</field>
        <field name="model">proofing.file.review</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="file_id"/>
                            <field name="step_id"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'approved'"
                                   decoration-info="state == 'in_review'"
                                   decoration-warning="state == 'changes_requested'"
                                   decoration-muted="state == 'not_started'"/>
                            <field name="decision_summary" string="Progress"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reviewer Decisions" name="decisions">
                            <field name="decision_ids">
                                <list>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                    <field name="decision" widget="badge"
                                           decoration-success="decision == 'approved'"
                                           decoration-danger="decision == 'changes_requested'"
                                           decoration-muted="decision == 'pending'"/>
                                    <field name="decision_date"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Review Decision Tree -->
    <record id="proofing_review_decision_view_tree" model="ir.ui.view">
        <field name="name">proofing.review.decision.tree</field>
        <field name="model">proofing.review.decision</field>
        <field name="arch" type="xml">
            <list>
                <field name="file_id"/>
                <field name="step_id"/>
                <field name="project_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="decision" widget="badge"
                       decoration-success="decision == 'approved'"
                       decoration-danger="decision == 'changes_requested'"
                       decoration-muted="decision == 'pending'"/>
                <field name="decision_date"/>
                <button name="action_approve" string="Approve"
                        type="object" class="btn-success"
                        invisible="decision == 'approved'"/>
                <button name="action_request_changes" string="Request Changes"
                        type="object" class="btn-warning"
                        invisible="decision == 'changes_requested'"/>
            </list>
        </field>
    </record>

    <!-- Review Decision Form -->
    <record id="proofing_review_decision_view_form" model="ir.ui.view">
        <field name="name">proofing.review.decision.form</field>
        <field name="model">proofing.review.decision</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="decision == 'approved'"/>
                    <button name="action_request_changes" string="Request Changes"
                            type="object" class="btn-warning"
                            invisible="decision == 'changes_requested'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="file_id"/>
                            <field name="step_id"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="decision"/>
                            <field name="decision_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="comment" placeholder="Leave a comment with your decision..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Review Decision Search -->
    <record id="proofing_review_decision_view_search" model="ir.ui.view">
        <field name="name">proofing.review.decision.search</field>
        <field name="model">proofing.review.decision</field>
        <field name="arch" type="xml">
            <search>
                <field name="file_id"/>
                <field name="project_id"/>
                <filter name="my_reviews" string="My Reviews"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="pending" string="Pending"
                        domain="[('decision', '=', 'pending')]"/>
                <filter name="awaiting_my_review" string="Awaiting My Review"
                        domain="[('user_id', '=', uid), ('decision', '=', 'pending')]"/>
            </search>
        </field>
    </record>

    <!-- My Reviews Action -->
    <record id="proofing_my_reviews_action" model="ir.actions.act_window">
        <field name="name">My Reviews</field>
        <field name="res_model">proofing.review.decision</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="proofing_review_decision_view_search"/>
        <field name="context">{'search_default_awaiting_my_review': 1}</field>
    </record>

</odoo>
