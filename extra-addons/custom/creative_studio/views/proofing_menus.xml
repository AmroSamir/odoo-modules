<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- Top-level menu -->
    <menuitem id="proofing_menu_root"
              name="Creative Studio"
              web_icon="creative_studio,static/description/icon.png"
              groups="creative_studio.group_proofing_user"
              sequence="100"/>

    <!-- Projects -->
    <menuitem id="proofing_menu_projects"
              name="Projects"
              parent="proofing_menu_root"
              action="proofing_project_action"
              sequence="10"/>

    <!-- Files -->
    <menuitem id="proofing_menu_files"
              name="Files"
              parent="proofing_menu_root"
              action="proofing_file_action"
              sequence="20"/>

    <!-- My Reviews -->
    <menuitem id="proofing_menu_my_reviews"
              name="My Reviews"
              parent="proofing_menu_root"
              action="proofing_my_reviews_action"
              sequence="30"/>

    <!-- Annotations -->
    <menuitem id="proofing_menu_annotations"
              name="Annotations"
              parent="proofing_menu_root"
              action="proofing_annotation_action"
              sequence="40"/>

    <!-- Configuration -->
    <menuitem id="proofing_menu_config"
              name="Configuration"
              parent="proofing_menu_root"
              groups="creative_studio.group_proofing_manager"
              sequence="90"/>

    <menuitem id="proofing_menu_config_steps"
              name="Review Steps"
              parent="proofing_menu_config"
              action="proofing_review_step_action"
              sequence="10"/>

    </data>
</odoo>
