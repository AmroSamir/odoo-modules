<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="proofing_file_view_tree" model="ir.ui.view">
        <field name="name">proofing.file.tree</field>
        <field name="model">proofing.file</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="current_version_number" string="Version"/>
                <field name="file_type" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="proofing_file_view_form" model="ir.ui.view">
        <field name="name">proofing.file.form</field>
        <field name="model">proofing.file</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_upload_new_version" string="Upload New Version"
                            type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="File Name"/>
                            <span class="text-muted ms-2">
                                v<field name="current_version_number" class="d-inline"/>
                            </span>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="file_type"/>
                        </group>
                    </group>

                    <!-- Preview area -->
                    <group string="Preview">
                        <field name="thumbnail" widget="image"
                               invisible="file_type != 'image'"
                               options="{'size': [800, 600]}"/>
                        <field name="current_version_id" invisible="1"/>
                    </group>

                    <notebook>
                        <page string="Review Status" name="reviews">
                            <field name="file_review_ids">
                                <list>
                                    <field name="step_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'approved'"
                                           decoration-info="state == 'in_review'"
                                           decoration-warning="state == 'changes_requested'"
                                           decoration-muted="state == 'not_started'"/>
                                    <field name="decision_summary" string="Approved"/>
                                </list>
                            </field>
                        </page>

                        <page string="Versions" name="versions">
                            <field name="version_ids">
                                <list>
                                    <field name="version_number"/>
                                    <field name="filename"/>
                                    <field name="uploaded_by" widget="many2one_avatar_user"/>
                                    <field name="upload_date"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="proofing_file_view_search" model="ir.ui.view">
        <field name="name">proofing.file.search</field>
        <field name="model">proofing.file</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="proofing_file_action" model="ir.actions.act_window">
        <field name="name">Files</field>
        <field name="res_model">proofing.file</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="proofing_file_view_search"/>
    </record>

</odoo>
