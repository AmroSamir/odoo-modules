<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="utm_campaign_view_form_inherit_creative_studio" model="ir.ui.view">
        <field name="name">utm.campaign.form.inherit.creative.studio</field>
        <field name="model">utm.campaign</field>
        <field name="inherit_id" ref="utm.utm_campaign_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Proofing Projects" name="proofing_projects">
                    <field name="proofing_project_ids" mode="kanban" nolabel="1"
                           context="{'default_campaign_id': id}">
                        <kanban create="false" edit="false">
                            <field name="id"/>
                            <field name="name"/>
                            <field name="owner_id"/>
                            <field name="file_count"/>
                            <field name="approval_summary"/>
                            <field name="active_step_name"/>
                            <field name="latest_version_number"/>
                            <templates>
                                <t t-name="card">
                                    <div style="min-width: 280px; max-width: 360px; padding: 16px;">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <strong class="fs-6">
                                                <field name="name"/>
                                            </strong>
                                            <span class="badge text-bg-light">
                                                v<field name="latest_version_number"/>
                                            </span>
                                        </div>
                                        <div class="text-muted small mb-2">
                                            <field name="owner_id" widget="many2one_avatar_user"/>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="badge" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; font-size: 11px; font-weight: 600;">
                                                <field name="approval_summary"/>
                                            </span>
                                            <span class="text-muted" style="font-size: 11px;">
                                                <field name="file_count"/> files
                                            </span>
                                        </div>
                                        <div t-if="record.active_step_name.raw_value"
                                             class="text-muted" style="font-size: 11px;">
                                            Step: <field name="active_step_name"/>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
