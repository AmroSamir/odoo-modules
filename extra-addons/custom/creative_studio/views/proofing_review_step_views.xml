<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="proofing_review_step_view_tree" model="ir.ui.view">
        <field name="name">proofing.review.step.tree</field>
        <field name="model">proofing.review.step</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="reviewer_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="proofing_review_step_view_form" model="ir.ui.view">
        <field name="name">proofing.review.step.form</field>
        <field name="model">proofing.review.step</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="reviewer_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="proofing_review_step_action" model="ir.actions.act_window">
        <field name="name">Review Steps</field>
        <field name="res_model">proofing.review.step</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
